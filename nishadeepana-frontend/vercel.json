{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        { "source": "/sitemap.xml", "destination": "https://nishadeepana-sarees.onrender.com/sitemap.xml" },
        { "source": "/robots.txt", "destination": "/robots.txt" },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}